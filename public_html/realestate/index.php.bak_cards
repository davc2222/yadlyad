                    if (!empty($ad['deal_type']) && dealTypeText($ad['deal_type']) !== '') $details[] = dealTypeText($ad['deal_type']);
                    if (hasVal($ad['rooms'])) $details[] = $ad['rooms'] . ' חדרים';
                    if (!empty($ad['square_meters'])) $details[] = (int) $ad['square_meters'] . ' מ״ר';
                    ?>

                    <?php
                    $adId = (int) $ad['id'];
                    $phone = trim($ad['phone'] ?? '');
                    $cleanPhone = preg_replace('/[^0-9+]/', '', $phone);

                    $addressParts = [];

                    if (!empty($ad['street'])) {
                        $addressParts[] = $ad['street'];
                    }

                    if (!empty($ad['neighborhood'])) {
                        $addressParts[] = $ad['neighborhood'];
                    }

                    $address = implode(' · ', $addressParts);
                    ?>

                    <article class="property-card">

                        <div class="property-image-wrap">

                            <a class="property-image-link"
                               href="/realestate/view.php?id=<?= $adId ?>">

                                <?php if ($img !== ''): ?>
                                    <img
                                        src="<?= e($img) ?>"
