                    <option value="rent" <?= $dealType === 'rent' ? 'selected' : '' ?>>השכרה</option>
                    <option value="roommates" <?= $dealType === 'roommates' ? 'selected' : '' ?>>שותפים</option>
                    <option value="commercial" <?= $dealType === 'commercial' ? 'selected' : '' ?>>מסחרי</option>
