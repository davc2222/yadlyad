</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const region = document.getElementById('region_id');
    const city = document.getElementById('city_id');

    if (!region || !city) {
        return;
    }

    region.addEventListener('change', async function () {
        city.innerHTML = '<option value="0">טוען ערים...</option>';
        city.disabled = true;

        if (!this.value || this.value === '0') {
            city.innerHTML = '<option value="0">כל הערים</option>';
            return;
        }

        try {
            const response = await fetch(
                '/ajax/get_cities.php?region_id='
                + encodeURIComponent(this.value),
                {cache: 'no-store'}
            );

            if (!response.ok) {
                throw new Error('HTTP ' + response.status);
            }

            const cities = await response.json();

            city.innerHTML = '<option value="0">כל הערים</option>';

            cities.forEach(function (item) {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = item.name;
                city.appendChild(option);
            });

            city.disabled = false;

        } catch (error) {
            console.error(error);

            city.innerHTML =
                '<option value="0">שגיאה בטעינת ערים</option>';
        }
    });
});
</script>

<?php require_once '../includes/footer.php'; ?>